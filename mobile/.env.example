# Point at production API by default. Override for local dev:
# EXPO_PUBLIC_API_URL=http://localhost:1979/api/v1
EXPO_PUBLIC_API_URL=https://order-envy.vercel.app/api/v1

# Google Sign-In (web client ID is required; add iOS/Android for standalone builds)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Leave iOS/Android blank until you have dev builds — placeholders break Expo Go sign-in
# For more reliable Expo Go on iPhone, create an iOS OAuth client with bundle ID: host.exp.Exponent
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# Expo Go redirect (register in Google Console Web client): https://auth.expo.io/@resonating-bytes/order-envy
