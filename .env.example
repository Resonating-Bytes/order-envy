# Database
DATABASE_URL=mongodb://localhost:27017/orderenvy
# Optional: override test database (defaults to orderenvy_test on same host)
# TEST_DATABASE_URL=mongodb://localhost:27017/orderenvy_test

# Auth
JWT_SECRET=change-me-to-a-long-random-string
SESSION_SECRET=change-me-to-a-long-random-string

# Google Sign-In (API verifies mobile ID tokens)
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-web-client-secret
GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com

# Mobile (Expo) — set in mobile/.env or EAS secrets
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com

# App
PORT=1979
APP_ORIGIN=http://localhost:1979
CORS_ORIGIN=http://localhost:1979

# API compatibility metadata (optional overrides for /api/v1/meta/compatibility)
# API_BACKEND_REVISION=20260620100000
# API_MIN_APP_VERSION=1.0.0
# API_LATEST_APP_VERSION=1.0.0  # optional; defaults to mobile/app.json expo.version

# External services
GEO_KEY=your-mapquest-api-key
EMAIL=your-gmail-address@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
