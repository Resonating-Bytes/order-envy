<% if (recommendations.length) { %>
    <%- include("./deleteConfirm") %>

    <h2 class="page-header">Recommendations</h2>
    <% recommendations.forEach((recommendation) => { %>
        <%
            let linkName = recommendation.restaurant.name;
            let menuItemPart = ``;
            if ('menuItem' in recommendation && recommendation.menuItem) {
                menuItemPart += `/menuItems/${recommendation.menuItem._id}`;
                linkName = recommendation.menuItem.name;
            }
            const menuItemPage = ('from' in recommendation);
            if (menuItemPage) {
        %>
            <div class="row new-item-form no-margin">
                by:
                <% recommendation.from.forEach((from) => { %>
                    <br>
                    <%- from._id.equals(user._id) ? "me" : from.getFullName() %>
                <% }); %>
            </div>
        <%
            }
        %> 
        <div class="row new-item-form no-margin">
            <% if ('noDelete' in recommendation && recommendation.noDelete) { %>
                <div class="col-12 low-padding">
            <% } else { %>
                <div class="col-10 low-padding">
            <% } %>
                <a class="btn btn-outline-primary bg-light centered" href="/restaurants/<%= recommendation.restaurant._id %><%= menuItemPart %>">
                    <%= linkName %>
                </a>
            </div>

            <% if (!('noDelete' in recommendation && recommendation.noDelete)) { %>
            <div class="col-2 low-padding">
                <form class="delete-item" action="/users/share/<%= user._id %>/<%= recommendation._id %>?_method=DELETE" onsubmit="return deleteConfirm(`the recommendation for <%= linkName %>`)" method="POST">
                    <button class="btn btn-outline-danger">
                        <i class="fas fa-trash"></i>
                    </button>
                </form>
            </div>
            <% } %>
        </div>
    <% }); %>

    <hr class="spacer">
<% } %>
