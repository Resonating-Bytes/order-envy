<h2>
    <div class="row">
        <div class="col-9 page-header">
            Ratings
        </div>
        <div class="col-3">
            <% if (user) { %>
                <a href="<%= baseRatingLink %>/new" class="btn btn-xs btn-outline-primary bg-light" title="New Rating">
                    <i class="fa-solid fa-plus"></i>
                </a>
            <% } %>
        </div>
    </div>
</h2>
<% if (ratings.length) { %>
    <div class="menu-item-container">
        <div class="container">
            <div class="row">
                <div class="col-5 no-padding">
                    <h5 class="sub-header-text">Rating</h5>
                </div>
                <div class="col-7 no-padding">
                    <h5 class="sub-header-text">Comment</h5>
                </div>
            </div>
        </div>
        <div class="container">
            <% ratings.forEach((ratingData, idx) => { %>
                <% if (idx > 0) { %>
                    <hr class="spacer low-margin">
                <% } %>

                <div class="row">
                    <div class="col">
                        <div class="rating-btn">
                            <% const ri = getRatingInfo(ratingInfo, ratingData.rating) %>
                            <img src="<%= ri.img %>.png" alt="<%= ri.alt %>" title="<%= ri.title %>">
                        </div>
                        <div class="rating-btn">
                            <a class="btn btn-outline-warning bg-light" href="<%= baseRatingLink %>/<%= ratingData._id %>">
                                <i class="fas fa-edit"></i>
                            </a>
                        </div>
                        <div class="rating-content low-padding">
                            <%= ratingData.comment %>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
<% } %>
