<h2>
    <div class="row">
        <div class="col-10">
            Ratings
        </div>
        <div class="col-2">
            <% if (user) { %>
                <a href="<%= baseRatingLink %>/new" class="btn btn-xs btn-outline-primary bg-light" title="New Rating">
                    <i class="fa-solid fa-plus"></i>
                </a>
            <% } %>
        </div>
    </div>
</h2>
<% if (ratings.length) { %>
    <div class="menu-item-container">
        <div class="row">
            <div class="col-2">
                <h5>Rating</h5>
            </div>
            <div class="col-9">
                <h5>Comment</h5>
            </div>
        </div>
        <div class="container">
            <% ratings.forEach((ratingData) => { %>
                <div class="row rating">
                    <div class="col-2">
                        <% const ri = getRatingInfo(ratingInfo, ratingData.rating) %>
                        <img src="<%= ri.img %>Small.png" alt="<%= ri.alt %>" title="<%= ri.title %>">
                    </div>
                    <div class="col-9">
                        <%= limitText(ratingData.comment, 30) %>
                    </div>
                    <div class="col-1">
                        <a class="btn btn-outline-warning bg-light float-right" href="<%= baseRatingLink %>/<%= ratingData._id %>">
                            <i class="fas fa-edit"></i>
                        </a>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
<% } %>
