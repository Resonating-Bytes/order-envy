<%- include("../partials/header") %>

    <div style="text-align:center">
        <h1>Add a menu item</h1>
    </div>

    <div class="new-item-form">
        <form class="form-inline" action="/restaurants/<%= restaurant._id %>/menuItems" method="POST">
            <div class="form-group">
                <input class="form-control" type="text" name="menuItem[name]" placeholder="Name" autofocus>
            </div>
            <div class="form-group">
                <input class="form-control" type="text" name="menuItem[description]" placeholder="Description">
            </div>
            <div class="form-group">
                <select class="form-control" name="menuItem[category]">
                    <% const categories = MenuItem.getCategories(); categories.forEach((category, idx) => { %>
                        <option value="<%= category %>" <%= category === 'Entree' ? 'selected' : '' %>><%= category %></option>
                    <% }); %>
                </select>
            </div>

            <hr class="spacer">

            <div class="row">
                <div class="col right-align">
                    <input type="radio" name="menuItem[nextAction]" value="rating" id="menuItem[nextAction]" placeholder="Add a rating for this item next" checked />
                </div>  
                <div class="col-10">
                    Add a new rating for this menu item
                </div>  
            </div>  
            <div class="row">
                <div class="col right-align">
                    <input type="radio" name="menuItem[nextAction]" value="recommend" id="menuItem[nextAction]" placeholder="Recommend next time" />
                </div>  
                <div class="col-10">
                    Recommend this menu item next time
                </div>  
            </div>

            <hr class="spacer">

            <%- include("../partials/formButtons") %>
        </form>
    </div>

<%- include("../partials/footer") %>