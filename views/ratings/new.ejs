<%- include("../partials/header") %>

    <div style="text-align:center">
        <h1>Add a rating</h1>
    </div>

    <div class="new-item-form">
        <form class="form-inline" action="<%= restaurantRoute %><%= menuItemRoute %>/ratings" method="POST">
            <div class="form-group">
                <%- include("../partials/ratingInput") %>
            </div>
            <div class="form-group">
                <input class="form-control" type="text" name="comment" placeholder="Comment" autofocus>
            </div>

            <%- include("../partials/formButtons") %>
        </form>
    </div>

<%- include("../partials/footer") %>