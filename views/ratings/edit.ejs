<%- include("../partials/header") %>

    <div style="text-align:center">
        <h1>Edit a rating</h1>
    </div>

    <div class="new-item-form">
        <form action="<%= restaurantRoute %><%= menuItemRoute %>/ratings/<%= rating._id %>?_method=PUT" method="POST">
            <div class="form-group">
                <%- include("../partials/ratingInput") %>
            </div>
            <div class="form-group">
                <input class="form-control" type="text" name="rating[comment]" placeholder="Comment" value="<%= rating.comment %>">
            </div>

            <%- include("../partials/formButtons") %>
        </form>
    </div>

<%- include("../partials/footer") %>