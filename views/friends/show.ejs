<%- include("../partials/header") %>

    <div class="row">
        <div class="col-2">
            <a class="btn btn-outline-primary bg-light" href="/users/<%= user._id %>/friends" title="Friends List">
                <i class="fas fa-chevron-left"></i>
            </a>
        </div>
        <div class="col-10">
            <div class="page-header">Recent ratings from</div>
            <br>
            <div class="header-text"><%= friendName %></div>
        </div>
    </div>

    <hr class="spacer">

    <div class="container">
        <% if (recent.length == 0) { %>
            <div class="row">
                <div class="col-8 centered">
                    <h2 class="header-text">
                        No ratings, tell them to get out and live a little!
                    </h2>
                </div>
            </div>
        <% } %> 

        <% recent.forEach((info, idx) => { %>
            <% if (idx > 0) { %>
                <hr class="spacer low-margin">
            <% } %>

            <div class="row">
                <div class="col-5">
                    <div class="row">
                        <%= new Date(info.ratingData.createdAt).toLocaleDateString() %>
                    </div>
                    <div class="row">
                        <div class="col-5">
                            <% const ri = getRatingInfo(ratingInfo, info.ratingData.rating) %>
                            <img src="<%= ri.img %>.png" alt="<%= ri.alt %>" title="<%= ri.title %>">
                        </div>
                        <div class="col-7">
                            <% if (recommendations.indexOf((info.menuItem ? info.menuItem._id : info.restaurant._id).valueOf()) === -1) { %>
                                <!-- link to create a recommendation -->
                                <%
                                let restaurantPart = `restaurant=${info.restaurant._id}`;
                                let menuItemPart = ``; 
                                if (info.menuItem) {
                                    menuItemPart += `&menuItem=${info.menuItem._id}`;
                                }
                                %>
                                <a class="btn btn-outline-primary bg-light" href="/users/share/<%= user._id %>?<%= restaurantPart %><%= menuItemPart %>" title="Add Recommendation">
                                    <i class="fa-regular fa-star"></i>
                                </a>
                            <% } else { %>
                                <!-- already has a recommendatino, show a solid star instead -->
                                <i class="fa-solid fa-star btn-outline-primary centered recommendation-exists"></i>
                            <% } %>
                        </div>
                    </div>
                </div>
                <div class="col-7">
                    <div class="row">
                        <% if (info.restaurant) { %>
                            <% if (info.menuItem) { %>
                                <a href="/restaurants/<%= info.restaurant._id %>/menuItems/<%= info.menuItem._id %>">
                                    <%= info.menuItem.name %>
                                </a>
                            <% } else { %>
                                <a href="/restaurants/<%= info.restaurant._id %>">
                                    <%= info.restaurant.name %>
                                </a>
                            <% } %>
                        <% } %>
                    </div>
                    <div class="row">
                        <%= info.ratingData.comment %>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>

    <br>

    <div class="row">
        <div class="col-2">
            <% if (prevPage !== undefined) { %>
                <a class="btn btn-outline-primary bg-light navigation" href="<%= prevPage %> " title="Previous Page">
                    <i class="fas fa-chevron-left"></i>
                </a>
            <% } %>
        </div>
        <div class="col-6">
        </div>
        <div class="col-2">
            <% if (nextPage !== undefined) { %>
                <a class="btn btn-outline-primary bg-light navigation" href="<%= nextPage %> " title="Next Page">
                    <i class="fas fa-chevron-right"></i>
                </a>
            <% } %>
        </div>
    </div>

<%- include("../partials/footer") %>
