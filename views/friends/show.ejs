<%- include("../partials/header") %>

    <div class="row">
        <div class="col-2">
            <a class="btn btn-outline-primary bg-light" href="/users/<%= user._id %>/friends" title="Friends List">
                <i class="fas fa-chevron-left"></i>
            </a>
        </div>
    </div>
    <hr class="spacer">

    <h2>Recent ratings from <%= friendName %></h2>
    <br>

    <div class="container">
        <% if (recent.length == 0) { %>
            <div class="row">
                <div class="col-8 centered">
                    <h2 class="sub-header-text">
                        No ratings, tell them to get out and live a little!
                    </h2>
                </div>
            </div>
        <% } %> 

        <% recent.forEach((info, idx) => { %>
            <% if (idx > 0) { %>
                <hr class="spacer low-margin">
            <% } %>

            <div class="row">
                <div class="col-4">
                    <div class="row">
                        <%= new Date(info.ratingData.createdAt).toLocaleDateString() %>
                    </div>
                    <div class="row">
                        <% const ri = getRatingInfo(ratingInfo, info.ratingData.rating) %>
                        <img src="<%= ri.img %>.png" alt="<%= ri.alt %>" title="<%= ri.title %>">
                    </div>
                </div>
                <div class="col-8">
                    <div class="row">
                        <% if (info.restaurant) { %>
                            <% if (info.menuItem) { %>
                                <a href="/restaurants/<%= info.restaurant._id %>/menuItems/<%= info.menuItem._id %>">
                                    <%= info.menuItem.name %>
                                </a>
                            <% } else { %>
                                <a href="/restaurants/<%= info.restaurant._id %>">
                                    <%= info.restaurant.name %>
                                </a>
                            <% } %>
                        <% } %>
                    </div>
                    <div class="row">
                        <%= info.ratingData.comment %>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>

    <br>

    <div class="row">
        <div class="col-2">
            <% if (prevPage !== undefined) { %>
                <a class="btn btn-outline-primary bg-light navigation" href="<%= prevPage %> " title="Previous Page">
                    <i class="fas fa-chevron-left"></i>
                </a>
            <% } %>
        </div>
        <div class="col-6">
        </div>
        <div class="col-2">
            <% if (nextPage !== undefined) { %>
                <a class="btn btn-outline-primary bg-light navigation" href="<%= nextPage %> " title="Next Page">
                    <i class="fas fa-chevron-right"></i>
                </a>
            <% } %>
        </div>
    </div>

<%- include("../partials/footer") %>
