<%- include("../partials/header") %>

    <script>
        function validateForm(name) {
            if (!document.forms[name].address.value && !confirm(`Are you sure you want to create a restaurant with no address?`)) {
                return false;
            }

            return validateAddress(name);
        }
    </script>

    <div style="text-align:center">
        <h1>Create a new restaurant</h1>
    </div>

    <div class="new-item-form">
        <form id="restaurant" class="form-inline" action="/restaurants" method="POST" onsubmit="return validateForm('restaurant')">
            <div class="form-group">
                <input class="form-control" type="text" name="name" placeholder="Restaurant name" autofocus>
            </div>
            <div class="form-group">
                <input class="form-control" type="text" name="website" placeholder="Website">
            </div>
            <div class="form-group">
                <input class="form-control" type="text" name="phone" placeholder="Phone">
            </div>
            <div class="form-group">
                <input class="form-control" type="text" name="description" placeholder="Description">
            </div>
            <div class="form-group">
                <input id="address" class="form-control" type="text" name="address" placeholder="Address (at least City, State)" onchange="invalidateLatLong()">
            </div>
            <div class="form-group">
                <input id="lat" class="form-control" type="hidden" name="lat" placeholder="Latitude">
            </div>
            <div class="form-group">
                <input id="long" class="form-control" type="hidden" name="long" placeholder="Longitude">
            </div>
            <div class="row-spacer">
                <div id="findMe" class="btn btn-success" onclick="findMe('form')">Find me</div>
            </div>

            <%- include("../partials/formButtons") %>
        </form>
    </div>

<%- include("../partials/footer") %>