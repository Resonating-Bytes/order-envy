<%- include("./partials/header") %>

    <%- include("./partials/validatePassword") %>

    <div class="centered">
        <h1>Sign up form</h1>

        <form class="new-item-form" action="/register" onsubmit="return validateForm('password')" method="POST" name="oeForm">
            <div class="container">
                <div class="row form-group">
                    <div class="col-8 centered">
                        <input class="form-control" type="text" name="username" placeholder="Email" autofocus>
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-8 centered">
                        <input class="form-control" type="password" name="password" placeholder="password">
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-8 centered">
                        <input class="form-control" type="password" name="confirmPassword" placeholder="confirm password">
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-8 centered">
                        <input class="form-control" type="text" name="firstName" placeholder="First Name (optional)">
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-8 centered">
                        <input class="form-control" type="text" name="lastName" placeholder="Last Name (optional)">
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-8 centered">
                        <button class="form-control btn btn-primary float-right">Submit</button>
                    </div>
                </div>
            </div>
        </form>
    </div>

<%- include("./partials/footer") %>
