<%- include("./partials/header") %>

    <div class="centered">
        <h1>Reset Password for <%= email %></h1>

        <form class="new-item-form" action="/resetPassword" method="POST">
            <div class="container">
                <div class="row form-group">
                    <div class="col-8 centered">
                        <input class="form-control" type="text" name="token" value="<%= token %>" hidden>
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-8 centered">
                        <input class="form-control" type="password" name="newPassword" placeholder="new password">
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-8 centered">
                        <input class="form-control" type="password" name="confirmPassword" placeholder="confirm password">
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-8 centered">
                        <button class="form-control btn btn-primary float-right">Submit</button>
                    </div>
                </div>
            </div>
        </form>
    </div>

<%- include("./partials/footer") %>
